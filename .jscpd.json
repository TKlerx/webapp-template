{
  "threshold": 3.0,
  "min-lines": 5,
  "min-tokens": 50,
  "reporters": ["console"],
  "absolute": true,
  "ignore": [
    "**/tests/**",
    "**/test-results/**",
    "**/playwright-report/**",
    "**/coverage/**",
    "**/dist/**",
    "**/build/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/.next/**",
    "**/generated/**",
    "**/node_modules/**"
  ]
}

