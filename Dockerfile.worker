FROM python:3.12-slim

WORKDIR /worker

RUN pip install --no-cache-dir uv

COPY worker/pyproject.toml ./pyproject.toml
COPY worker/uv.lock ./uv.lock
COPY worker/README.md ./README.md
COPY worker/src ./src

RUN uv sync --frozen --no-dev

RUN groupadd --system --gid 1001 worker \
    && useradd --system --uid 1001 --gid worker starter-worker \
    && chown -R starter-worker:worker /worker
USER starter-worker

CMD [".venv/bin/starter-worker"]
