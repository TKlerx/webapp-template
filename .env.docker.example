# Used by `pnpm docker ...`.
#
# Values here override local-development values from .env for Compose interpolation.

POSTGRES_DB=business_app_starter
POSTGRES_USER=starter
POSTGRES_PASSWORD=replace-with-a-real-docker-secret
POSTGRES_CONNECTION_LIMIT=10
APP_DATABASE_URL=postgresql://starter:replace-with-a-real-docker-secret@postgres:5432/business_app_starter?connection_limit=10
WORKER_DATABASE_URL=postgresql://starter:replace-with-a-real-docker-secret@postgres:5432/business_app_starter?connection_limit=10
MIGRATION_DATABASE_URL=postgresql://starter:replace-with-a-real-docker-secret@postgres:5432/business_app_starter?connection_limit=2

BASE_PATH=/webapp-template
APP_ENVIRONMENT=local
APP_VERSION=local
APP_REVISION=unknown
APP_BUILD_ID=docker-compose
APP_BUILT_AT=unknown
PORT=3270
AUTH_BASE_URL=http://localhost:3270/webapp-template
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
TRUST_PROXY_HEADERS=0
TRUST_PROXY_HEADER_SECRET=
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-real-initial-admin-password
