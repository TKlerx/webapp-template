generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLATFORM_ADMIN
  SCOPE_ADMIN
  SCOPE_USER
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
}

enum AuthMethod {
  SSO
  LOCAL
  BOTH
}

enum ThemePreference {
  LIGHT
  DARK
}

enum TokenType {
  PAT
  CLI_LOGIN
}

enum TokenStatus {
  ACTIVE
  REVOKED
}

enum AuditAction {
  USER_CREATED
  ROLE_CHANGED
  SCOPE_ASSIGNMENT_CHANGED
  USER_STATUS_CHANGED
  USER_THEME_CHANGED
  AUTH_LOGIN_SUCCEEDED
  AUTH_LOGIN_REJECTED
  AUTH_PASSWORD_CHANGED
  AUTH_LOGOUT_SUCCEEDED
  AUDIT_EXPORT_REQUESTED
  PAT_CREATED
  PAT_REVOKED
  PAT_RENEWED
  PAT_DELETED
  CLI_LOGIN_COMPLETED
}

enum BackgroundJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  emailVerified      Boolean                 @default(false)
  name               String
  image              String?
  role               Role                    @default(SCOPE_USER)
  status             UserStatus              @default(PENDING_APPROVAL)
  authMethod         AuthMethod
  mustChangePassword Boolean                 @default(true)
  themePreference    ThemePreference         @default(LIGHT)
  locale             String                  @default("en")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  accounts           Account[]
  sessions           Session[]
  scopeAssignments   UserScopeAssignment[]
  auditEntries       AuditEntry[]            @relation("AuditActor")
  backgroundJobs     BackgroundJob[]         @relation("BackgroundJobCreator")
  personalAccessTokens PersonalAccessToken[]
  cliAuthCodes       CliAuthCode[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Scope {
  id              String                  @id @default(cuid())
  name            String                  @unique
  code            String                  @unique
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  userAssignments UserScopeAssignment[]
  auditEntries    AuditEntry[]
}

model UserScopeAssignment {
  id        String   @id @default(cuid())
  userId    String
  scopeId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope     Scope    @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([userId, scopeId])
  @@index([scopeId])
}

model AuditEntry {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String
  actorId    String
  scopeId    String?
  details    String
  createdAt  DateTime    @default(now())
  actor      User        @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  scope      Scope?      @relation(fields: [scopeId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([scopeId])
  @@index([createdAt])
}

model PersonalAccessToken {
  id           String      @id @default(cuid())
  name         String
  tokenHash    String      @unique
  tokenPrefix  String
  userId       String
  type         TokenType
  expiresAt    DateTime
  lastUsedAt   DateTime?
  status       TokenStatus @default(ACTIVE)
  revokedAt    DateTime?
  renewalCount Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([tokenHash])
  @@index([userId, status])
  @@index([status, expiresAt])
}

model CliAuthCode {
  id          String   @id @default(cuid())
  code        String   @unique
  state       String
  callbackUrl String
  userId      String?
  exchanged   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([expiresAt])
}

model BackgroundJob {
  id              String              @id @default(cuid())
  jobType         String
  status          BackgroundJobStatus @default(PENDING)
  payload         String
  result          String?
  error           String?
  attemptCount    Int                 @default(0)
  availableAt     DateTime            @default(now())
  startedAt       DateTime?
  lockedAt        DateTime?
  finishedAt      DateTime?
  workerId        String?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       User?               @relation("BackgroundJobCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([createdByUserId, createdAt])
  @@index([jobType, createdAt])
}
