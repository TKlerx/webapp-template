{
  "name": "business-app-starter",
  "version": "1.0.0",
  "description": "Reusable internal business app starter",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build",
    "start": "node scripts/run-next.mjs start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "duplication": "jscpd src/ --config .jscpd.json --pattern \"**/*.{ts,tsx,js,jsx}\"",
    "semgrep": "semgrep scan --error --config auto --config .semgrep.yml",
    "continuity:update": "node scripts/update-continuity.mjs",
    "specs:overview:update": "node scripts/update-spec-overview.mjs",
    "specs:overview:check": "node scripts/update-spec-overview.mjs --check",
    "validate": "npm run typecheck && npm run lint && npm run duplication && npm run semgrep && npm run test",
    "validate:full": "npm run validate && npm run test:e2e",
    "template:stamp": "node scripts/stamp-template-origin.mjs",
    "prisma:generate": "prisma generate",
    "prisma:generate:postgres": "prisma generate --config prisma.config.postgres.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:postgres": "prisma migrate dev --config prisma.config.postgres.ts",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.4",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jscpd": "^4.0.8",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  }
}
