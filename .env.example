# Local dev/test defaults to SQLite; Docker Compose requires a PostgreSQL URL.
# Do not rely on silent fallback: if DATABASE_URL is set to PostgreSQL,
# the app should fail loudly when PostgreSQL is unavailable.
# SQLite remains supported for local development and as the source for a one-time migration only.
# Prisma picks schema based on DATABASE_URL unless PRISMA_SCHEMA is set explicitly.
# PRISMA_SCHEMA="prisma/schema.postgres.prisma"
DATABASE_URL="file:./dev.db"

# PostgreSQL Docker/production configuration
POSTGRES_DB="business_app_starter"
POSTGRES_USER="starter"
POSTGRES_PASSWORD=""
POSTGRES_CONNECTION_LIMIT="10"
# Example Docker/production DATABASE_URL derived from the variables above:
# DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connection_limit=${POSTGRES_CONNECTION_LIMIT}"
# Docker Compose reads DATABASE_URL directly from .env and will fail fast if it is still a SQLite file URL.

# HTTP port for `npm run dev`, `npm run start`.
PORT=3270

# App base path for local and reverse-proxied deployments.
BASE_PATH=

# Public origin used to build BetterAuth callback and post-login URLs.
AUTH_BASE_URL=http://localhost:3270

# BetterAuth secret. Generate with `npx auth secret`.
BETTER_AUTH_SECRET=replace-with-at-least-32-characters

# Azure AD / Microsoft Entra ID app registration values.
# These power interactive user sign-in via Better Auth.
AZURE_AD_CLIENT_ID=replace-me
AZURE_AD_CLIENT_SECRET=replace-me
AZURE_AD_TENANT_ID=replace-me

# Microsoft Graph API (application credentials).
# Use separate app credentials for least privilege when needed.
# In smaller setups, these may intentionally be the same values as AZURE_AD_* above.
GRAPH_CLIENT_ID=replace-me
GRAPH_CLIENT_SECRET=replace-me
GRAPH_TENANT_ID=replace-me

# Observability
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Initial admin seed user created when the database is empty.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Personal access tokens and CLI login defaults.
PAT_TOKEN_PREFIX=starter_pat
PAT_DEFAULT_EXPIRY_DAYS=90
CLI_TOKEN_DEFAULT_EXPIRY_DAYS=30
PAT_MAX_ACTIVE_PER_USER=10

# Background worker polling interval in seconds.
WORKER_POLL_INTERVAL_SECONDS=3

# Background worker reliability controls.
# Retries remain visible in the Background Jobs dashboard through
# status, attemptCount, availableAt, workerId, and error.
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BACKOFF_SECONDS=15
WORKER_STALE_LOCK_SECONDS=300
